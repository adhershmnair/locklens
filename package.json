{
  "name": "locklens",
  "displayName": "LockLens",
  "description": "Inline resolved versions from lock files across npm, yarn, pnpm, bun, and composer.",
  "version": "0.2.0",
  "publisher": "adhershmnair",
  "icon": "media/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/adhershmnair/locklens"
  },
  "bugs": {
    "url": "https://github.com/adhershmnair/locklens/issues"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "npm",
    "yarn",
    "pnpm",
    "bun",
    "composer",
    "lockfile",
    "versions",
    "dependencies"
  ],
  "activationEvents": [
    "onLanguage:json",
    "onLanguage:jsonc"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "locklens.refresh",
        "title": "LockLens: Refresh resolved versions"
      },
      {
        "command": "locklens.toggle",
        "title": "LockLens: Toggle inline versions"
      }
    ],
    "configuration": {
      "title": "LockLens",
      "properties": {
        "locklens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show inline resolved versions."
        },
        "locklens.checkUpdates": {
          "type": "boolean",
          "default": true,
          "description": "Check the registry (npmjs / Packagist) for newer versions."
        },
        "locklens.colorize": {
          "type": "boolean",
          "default": true,
          "description": "Color the inline version (red when outdated, green otherwise). Turn off for a single neutral color."
        },
        "locklens.outdatedColor": {
          "type": "string",
          "default": "#d64545",
          "description": "Color used when a newer version is available on the registry."
        },
        "locklens.upToDateColor": {
          "type": "string",
          "default": "#64a46b",
          "description": "Color used otherwise."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  }
}
